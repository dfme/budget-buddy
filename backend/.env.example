# Vorlage für lokale Umgebungsvariablen.
# Kopieren nach `.env` und mit echten Werten füllen — `.env` wird NICHT committet.
#
# Secret erzeugen (mind. 256 Bit für HS256):
#   openssl rand -base64 48

# JWT-Secret für HS256-Signierung (BE-AUTH-01).
JWT_SECRET=

# Anthropic Claude API-Key (Kategorisierung + Monatsbericht).
ANTHROPIC_API_KEY=

# Optional: abweichender Pfad für die SQLite-Datei (Default: budgetbuddy.db).
# SQLITE_DB_PATH=budgetbuddy.db
