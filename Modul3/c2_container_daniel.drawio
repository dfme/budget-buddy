        <!-- ===== C1: WEB SPA ===== -->
        <mxCell id="spa" value="&lt;b style=&quot;font-size:14px&quot;&gt;Web SPA&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;font-size:10px&quot;&gt;[Container: Angular 19, TypeScript]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Onboarding-Wizard, PDF-Upload-Flow,&lt;br&gt;Dashboard mit Safe-to-Spend, Kategorien-&lt;br&gt;Übersicht und manuelle Korrektur.&lt;br&gt;&lt;br&gt;Signals · Reactive Forms · OnPush&lt;br&gt;Functional HTTP-Interceptor (JWT)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#3C7FC0;fontColor=#FFFFFF;align=center;arcSize=8;strokeWidth=2;fontSize=11;" vertex="1" parent="1">
