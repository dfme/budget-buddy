        <!-- ===== OUR SYSTEM ===== -->
        <mxCell id="budgetbuddy" value="&lt;b style=&quot;font-size:18px&quot;&gt;BudgetBuddy&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;font-size:11px&quot;&gt;[Software System — wir]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Web-App, die Schweizer Bank-PDFs einliest, Transaktionen&lt;br&gt;automatisch kategorisiert und einen wöchentlichen&lt;br&gt;Safe-to-Spend-Betrag berechnet.&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Angular SPA · Spring Boot 3.5 · SQLite · JWT (HS256)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;fillColor=#1168BD;strokeColor=#0D5091;fontColor=#FFFFFF;align=center;arcSize=8;strokeWidth=2;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="540" y="380" width="570" height="200" as="geometry" />
        </mxCell>

        <!-- ===== SUPPORTING / EXTERNAL SYSTEMS ===== -->
        <mxCell id="auth" value="&lt;b style=&quot;font-size:13px&quot;&gt;Auth / Identity&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;font-size:10px&quot;&gt;[intern, eigener Service]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Spring Security&lt;br&gt;bcrypt + JJWT&lt;br&gt;Stateless JWT (HS256)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#3C7FC0;fontColor=#FFFFFF;align=center;arcSize=8;strokeWidth=2;fontSize=11;" vertex="1" parent="1">
