        <mxCell id="qa_sec" value="&lt;b style=&quot;color:#C62828&quot;&gt;Security (Marc)&lt;/b&gt;&lt;br&gt;&lt;br&gt;• JWT HS256 + bcrypt (≥12) in API&lt;br&gt;• Single-File-DB → triviale nDSG-Löschung&lt;br&gt;• PDF nicht persistiert (in-memory)&lt;br&gt;• Nur 1 externe Außenkante (Claude)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;fontColor=#000000;align=left;verticalAlign=top;arcSize=4;strokeWidth=2;fontSize=11;spacingLeft=10;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="1055" width="490" height="115" as="geometry" />
        </mxCell>

        <mxCell id="qa_use" value="&lt;b style=&quot;color:#2E7D32&quot;&gt;Usability (Lara)&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Angular Signals + Reactive Forms → schneller Onboarding-Flow&lt;br&gt;• OpenAPI-Contract (Springdoc) → klare API für SPA&lt;br&gt;• Hybride Kategorisierung → Aha-Moment beim 1. Upload&lt;br&gt;• Null-Setup-DB → Devs bauen Features, nicht Infra" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontColor=#000000;align=left;verticalAlign=top;arcSize=4;strokeWidth=2;fontSize=11;spacingLeft=10;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="585" y="1055" width="490" height="115" as="geometry" />
        </mxCell>

        <mxCell id="qa_rel" value="&lt;b style=&quot;color:#1565C0&quot;&gt;Reliability (beide)&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Flyway-Migrationen → konsistentes Schema überall&lt;br&gt;• BigDecimal(19,2) → Beträge auf den Rappen genau&lt;br&gt;• Claude-Fallback auf &quot;Sonstiges&quot; → Import nie blockiert&lt;br&gt;• Spring Boot 3.5 LTS → planbare Lebensdauer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontColor=#000000;align=left;verticalAlign=top;arcSize=4;strokeWidth=2;fontSize=11;spacingLeft=10;spacingTop=10;" vertex="1" parent="1">
