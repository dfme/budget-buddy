        <mxCell id="db" value="&lt;b style=&quot;font-size:14px&quot;&gt;Database&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;font-size:10px&quot;&gt;[Container: SQLite 3.x + Flyway]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Users, Transaktionen, Fixkosten,&lt;br&gt;Sparziele, Lookup-Tabelle (user-lokal),&lt;br&gt;PDF-Hashes für Duplikat-Erkennung.&lt;br&gt;&lt;br&gt;BigDecimal(19,2) für Geld&lt;br&gt;Flyway-Migrationen versioniert" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#438DD5;strokeColor=#3C7FC0;fontColor=#FFFFFF;align=center;strokeWidth=2;fontSize=11;" vertex="1" parent="1">
