        <mxCell id="qa_title" value="Quality Attributes — wie die Container darauf einzahlen" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;" vertex="1" parent="1">
